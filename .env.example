# Supabase (required)
SUPABASE_PROJECT_ID=
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=

# Optional: service role for trusted server admin operations only
# SUPABASE_SERVICE_ROLE_KEY=

# Google OAuth — store here as source of truth.
# Paste the same values into Supabase Dashboard → Authentication → Providers → Google.
# NEVER prefix GOOGLE_CLIENT_SECRET with VITE_ (must stay server-side / in Supabase).
GOOGLE_CLIENT_ID=xxxxxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxx
# Same Client ID — required in the browser for Google Identity Services
VITE_GOOGLE_CLIENT_ID=xxxxxxxxxxxxxxxx.apps.googleusercontent.com

# Pin auth redirects in production builds (local dev still uses window.location.origin when unset)
# VITE_LUMINA_AUTH_REDIRECT_URL=https://lumina-evermore.vercel.app
